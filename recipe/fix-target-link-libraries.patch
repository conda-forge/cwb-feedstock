Fix mixing plain and keyword target_link_libraries signatures

ROOT's ROOT_GENERATE_DICTIONARY macro calls target_link_libraries with
keyword signature (PUBLIC/PRIVATE). CMake requires all calls for a given
target to use the same form. Add PUBLIC keyword to the plain call.

--- a/wat/CMakeLists.txt
+++ b/wat/CMakeLists.txt
@@ -62,7 +62,7 @@
 #Add all the include directories to the target
 target_include_directories(${PROJECT_NAME} PRIVATE ${CWB_INCLUDE_DIRS})

-target_link_libraries(${PROJECT_NAME} ROOT::TreePlayer ROOT::Core ROOT::Graf ROOT::FFTW ROOT::Tree ROOT::Gpad ROOT::Physics ${HEALPIX_LIBRARY})
+target_link_libraries(${PROJECT_NAME} PUBLIC ROOT::TreePlayer ROOT::Core ROOT::Graf ROOT::FFTW ROOT::Tree ROOT::Gpad ROOT::Physics ${HEALPIX_LIBRARY})

 #Generate the root dictionary
 ROOT_GENERATE_DICTIONARY(wavedict ${WAT_HDRS}
