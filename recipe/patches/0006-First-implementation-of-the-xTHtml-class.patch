diff --git a/tools/xhtml/CMakeLists.txt b/tools/xhtml/CMakeLists.txt
new file mode 100644
index 00000000..51f4db34
--- /dev/null
+++ b/tools/xhtml/CMakeLists.txt
@@ -0,0 +1,49 @@
+project(
+    XHTML
+    LANGUAGES CXX
+)
+
+#Include the master CMakeLists.txt
+include_directories(${CMAKE_CURRENT_SOURCE_DIR})
+
+set(XHTML_SRC xTClassDocOutput.cc xTDocDirective.cc xTDocInfo.cc xTDocOutput.cc xTDocParser.cc xTHtml.cc)
+
+#Get all the header files
+string(REGEX REPLACE "[.]cc" ".hh" XHTML_HDRS "${XHTML_SRC}")
+
+#list(APPEND XHTML_HDRS xTHtml.hh)
+
+#Make a local copy of the CWB_OPTS
+set(XHTML_OPTS ${CWB_OPTS})
+
+#Make a local copy of the CWB_INCLUDE_DIRS
+set(XHTML_INCLUDE_DIRS ${CWB_INCLUDE_DIRS})
+
+#Append the stft directory
+#list(APPEND XHTML_INCLUDE_DIRS ${CMAKE_CURRENT_LIST_DIR}/../stft)
+
+#Create the library
+add_library(${PROJECT_NAME} SHARED ${XHTML_SRC})
+
+#Set the target properties
+set_target_properties(${PROJECT_NAME} PROPERTIES PREFIX "")
+set_target_properties(${PROJECT_NAME} PROPERTIES OUTPUT_NAME "xTHtml")
+set_target_properties(${PROJECT_NAME} PROPERTIES LIBRARY_OUTPUT_DIRECTORY ${CMAKE_CURRENT_BINARY_DIR}/lib)
+
+#target_link_libraries(${PROJECT_NAME} PUBLIC xHtml)
+
+#Generate the root dictionary
+ROOT_GENERATE_DICTIONARY(xTHtml_dict ${XHTML_HDRS}
+    LINKDEF xhtml_LinkDef.h
+    MODULE ${PROJECT_NAME})
+
+#Add all the include directories to the target
+target_include_directories(${PROJECT_NAME} PRIVATE ${XHTML_INCLUDE_DIRS})
+
+target_link_libraries(${PROJECT_NAME} PUBLIC ROOT::Core)
+
+install(TARGETS ${PROJECT_NAME})
+#install(FILES ${XHTML_HDRS}
+#        TYPE INCLUDE)
+#install(FILES ${CMAKE_CURRENT_BINARY_DIR}/${CMAKE_SHARED_LIBRARY_PREFIX}${PROJECT_NAME}_rdict.pcm
+#        TYPE LIB)
