    virtual const char* GetEndTag() const { return "end_html"; }
    virtual Bool_t GetResult(TString& result);
 
-   ClassDef(TDocHtmlDirective, 0); // Handler for "Begin_Html"/"End_Html" for raw HTML in documentation comments
