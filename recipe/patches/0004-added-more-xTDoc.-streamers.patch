    ClassDef(xTDocDirective, 0); // xTHtml directive handler
 };
 
-class TDocHtmlDirective: public xTDocDirective {
+class xTDocHtmlDirective: public xTDocDirective {
 private:
    TString fText;     // HTML text to be kept
    Bool_t  fVerbatim; // whether we are in a <pre></pre> block
 public:
-   TDocHtmlDirective(): xTDocDirective("HTML"), fVerbatim(kFALSE) {}
-   virtual ~TDocHtmlDirective() {}
