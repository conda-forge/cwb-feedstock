+////////////////////////////////////////////////////////////////////////////////
+/// Inform the xTHtml object that one of its helper objects was deleted.
+/// Called by xTHtml::HelperBase::~HelperBase().
+
+void xTHtml::HelperDeleted(xTHtml::THelperBase* who)
+{
+   THelperBase* helpers[3] = {fPathDef, fModuleDef, fFileDef};
+   for (int i = 0; who && i < 3; ++i)
+      if (who == helpers[i])
+         helpers[i] = who = 0;
+}
