+////////////////////////////////////////////////////////////////////////////////
+/// Add some colors etc to a source entity, contained in str.
+/// The type of what's contained in str is given by type.
+/// It's called e.g. by xTDocParser::BeautifyLine().
+/// This function should assume that only str."End()"
+/// (i.e. str.Begin()+str.Length()) is valid.
+/// When inserting into str.String(), str.Length() must be updated.
+
+void xTDocOutput::DecorateEntityEnd(TString& str, Ssiz_t& pos, xTDocParser::EParseContext type)
+{
+   Ssiz_t originalLen = str.Length();
+
+   switch (type) {
+      case xTDocParser::kCode: break;
+      case xTDocParser::kComment:
+         str.Insert(pos, "</span>");
+         break;
+      case xTDocParser::kDirective:
+         break;
+      case xTDocParser::kString:
+         str.Insert(pos, "</span>");
+         break;
+      case xTDocParser::kKeyword:
+         str.Insert(pos, "</span>");
+         break;
+      case xTDocParser::kCPP:
+         str.Insert(pos, "</span>");
+         break;
+      case xTDocParser::kVerbatim:
+         str.Insert(pos, "</pre>");
+         break;
+      default:
+         Error("DecorateEntityBegin", "Unhandled / invalid entity type %d!", (Int_t)type);
+         return;
+   }
+   Ssiz_t addedLen = str.Length() - originalLen;
+   pos += addedLen;
+}
