+////////////////////////////////////////////////////////////////////////////////
+/// Default destructor
+
+xTHtml::~xTHtml()
+{
+   fDocEntityInfo.fClasses.Clear();
+   fDocEntityInfo.fModules.Clear();
+   if (gHtml == this) {
+      gROOT->GetListOfSpecials()->Remove(gHtml);
+      gHtml = 0;
+   }
+   delete fPathDef;
+   delete fModuleDef;
+   delete fFileDef;
+   delete fLocalFiles;
+}
