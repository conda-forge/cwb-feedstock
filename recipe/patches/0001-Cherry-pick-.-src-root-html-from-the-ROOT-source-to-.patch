+////////////////////////////////////////////////////////////////////////////////
+/// Create all permutations of path and xTHtml's input path:
+/// path being PP/ and xTHtml's input being .:include/:src/ gives
+/// .:./PP/:include:include/PP/:src/:src/PP
+
+void xTHtml::TFileDefinition::ExpandSearchPath(TString& path) const
+{
+   xTHtml* owner = GetOwner();
+   if (!owner) return;
+
+   TString pathext;
+   TString inputdir = owner->GetInputPath();
+   TString tok;
+   Ssiz_t start = 0;
+   while (inputdir.Tokenize(tok, start, xTHtml::GetDirDelimiter())) {
+      if (pathext.Length())
+         pathext += GetDirDelimiter();
+      if (tok.EndsWith("\\"))
+         tok.Remove(tok.Length() - 1);
+      pathext += tok;
+      if (path.BeginsWith(tok))
+         pathext += GetDirDelimiter() + path;
+      else
+         pathext += GetDirDelimiter() + tok + "/" + path;
+   }
+   path = pathext;
+
+}
