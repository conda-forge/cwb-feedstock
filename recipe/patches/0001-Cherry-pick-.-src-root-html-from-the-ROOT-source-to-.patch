+   void           LocateMethodsInSource(std::ostream& out);
+   void           LocateMethodsInHeaderInline(std::ostream& out);
+   void           LocateMethodsInHeaderClassDecl(std::ostream& out);
+   void           LocateMethods(std::ostream& out, const char* filename,
